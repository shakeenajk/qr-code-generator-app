---
// src/components/PricingPromo.astro
---

<section class="bg-white py-16 sm:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-12 text-gray-900 dark:text-white">
      When do you need a paid plan?
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Left: copy block -->
      <div class="space-y-6">
        <ul class="space-y-4" role="list">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-sm text-gray-700 dark:text-slate-300">Save and manage up to 100 QR codes (Starter) or 250 QR codes (Pro)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-sm text-gray-700 dark:text-slate-300">Create dynamic QR codes — change the destination URL without reprinting</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-sm text-gray-700 dark:text-slate-300">Track scan analytics — see when, where, and how often your QR codes are scanned</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-sm text-gray-700 dark:text-slate-300">Priority support and higher dynamic QR limits for professional use</span>
          </li>
        </ul>
        <a href="/pricing" class="text-sm text-[#2563EB] hover:underline font-bold">
          See full pricing details →
        </a>
      </div>

      <!-- Right: tier comparison -->
      <div class="space-y-4">
        <div class="bg-gray-50 dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-6">
          <p class="text-sm font-bold uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-3">Free</p>
          <p class="text-base font-bold text-gray-900 dark:text-white mb-1">5 saved QR codes</p>
          <p class="text-sm text-gray-600 dark:text-slate-400">3 dynamic QR codes · Basic analytics</p>
        </div>
        <div class="bg-gray-50 dark:bg-slate-800 rounded-xl border border-[#2563EB] p-6">
          <p class="text-sm font-bold uppercase tracking-wide text-[#2563EB] mb-3">Starter / Pro</p>
          <p class="text-base font-bold text-gray-900 dark:text-white mb-1">100–250 saved QR codes</p>
          <p class="text-sm text-gray-600 dark:text-slate-400">10–100 dynamic QR codes · Full analytics</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <a
            href="/signup"
            class="inline-block bg-[#2563EB] text-white text-sm font-bold px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors text-center focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
          >
            Get started free
          </a>
          <a
            href="/pricing"
            class="inline-block border border-[#2563EB] text-[#2563EB] text-sm font-bold px-6 py-3 rounded-lg hover:bg-blue-50 dark:hover:bg-slate-700 transition-colors text-center focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
          >
            Explore Pro
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
