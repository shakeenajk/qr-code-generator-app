---
// src/components/HowTo.astro
const steps = [
  {
    number: 1,
    heading: 'Choose your content type',
    description: 'Enter a URL, text, WiFi credentials, or contact details.',
    imgSrc: '/screenshots/step-1.png',
    imgAlt: 'Step 1: QR code generator showing the URL input tab selected',
  },
  {
    number: 2,
    heading: 'Customize the design',
    description: 'Pick colors, dot shapes, and embed your logo.',
    imgSrc: '/screenshots/step-2.png',
    imgAlt: 'Step 2: QR code customization panel showing color and shape options',
  },
  {
    number: 3,
    heading: 'Download instantly',
    description: 'Export as PNG or SVG — no account needed.',
    imgSrc: '/screenshots/step-3.png',
    imgAlt: 'Step 3: QR code download dialog with PNG and SVG options',
  },
];
---

<section class="bg-gray-50 dark:bg-[#0f172a] py-16 sm:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-12 text-gray-900 dark:text-white">
      How to Create a QR Code in 3 Steps
    </h2>
    <ol class="grid grid-cols-1 lg:grid-cols-3 gap-8" role="list">
      {steps.map((step) => (
        <li class="flex flex-col items-center text-center">
          <div class="w-11 h-11 rounded-full bg-[#2563EB] flex items-center justify-center mb-4 shrink-0">
            <span class="text-xl font-bold text-white" aria-hidden="true">{step.number}</span>
          </div>
          <img
            src={step.imgSrc}
            alt={step.imgAlt}
            class="w-full h-48 md:h-64 object-cover rounded-xl border border-gray-200 dark:border-slate-700 mb-4"
            loading="lazy"
            width="800"
            height="512"
          />
          <h3 class="text-base font-bold text-gray-900 dark:text-white mb-2">
            {step.heading}
          </h3>
          <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">
            {step.description}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>
