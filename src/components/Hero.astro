---
// src/components/Hero.astro
import QRGeneratorIsland from "./QRGeneratorIsland";
---

<section class="bg-white py-16 sm:py-24 dark:bg-[#0f172a]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 tracking-tight mb-6 dark:text-white">
      Free QR Code Generator
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10 dark:text-slate-300">
      Create custom QR codes for URLs, text, WiFi, and contact cards.
      No signup, no limits — download as PNG or SVG instantly.
    </p>

    <!-- Generator island mount point -->
    <div
      id="qr-generator-root"
      class="bg-gray-50 rounded-xl border border-gray-200 p-6 text-left dark:bg-slate-800 dark:border-slate-700"
      aria-label="QR code generator"
    >
      <QRGeneratorIsland client:visible />
    </div>
  </div>
</section>
