---
// src/components/Hero.astro
---

<section class="bg-white py-16 sm:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 tracking-tight mb-6">
      Free QR Code Generator
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
      Create custom QR codes for URLs, text, WiFi, and contact cards.
      No signup, no limits — download as PNG or SVG instantly.
    </p>

    <!-- Generator island mount point — Phase 2 drops React island here. DO NOT remove this div. -->
    <div
      id="qr-generator-root"
      class="min-h-[400px] bg-gray-50 rounded-xl border border-gray-200 flex items-center justify-center"
      aria-label="QR code generator"
    >
      <p class="text-gray-400 text-sm">QR generator loads here</p>
    </div>
  </div>
</section>
