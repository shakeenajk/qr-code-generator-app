---
// src/components/Features.astro

const features = [
  {
    icon: '🔗',
    title: 'Four Content Types',
    description: 'URLs, plain text, WiFi credentials, and vCard contacts — all supported.',
  },
  {
    icon: '🎨',
    title: 'Full Customization',
    description: 'Choose dot shapes, eye styles, colors, and gradients to match your brand.',
  },
  {
    icon: '🖼️',
    title: 'Logo Embedding',
    description: 'Upload your logo and embed it in the center of your QR code.',
  },
  {
    icon: '⬇️',
    title: 'PNG & SVG Export',
    description: 'Download print-ready PNG at 3× resolution or true vector SVG.',
  },
  {
    icon: '⚡',
    title: 'Instant Preview',
    description: 'Every change reflects live in the preview — no form submission needed.',
  },
  {
    icon: '🔒',
    title: 'No Signup Required',
    description: 'Completely free. No account, no data stored, no friction.',
  },
];
---

<section class="bg-gray-50 dark:bg-slate-900 py-16 sm:py-20" id="features">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white text-center mb-12">
      Everything You Need
    </h2>
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" role="list">
      {features.map((f) => (
        <li class="bg-white dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-6">
          <span class="text-3xl mb-3 block" aria-hidden="true">{f.icon}</span>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{f.title}</h3>
          <p class="text-gray-600 dark:text-slate-400 text-sm leading-relaxed">{f.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
