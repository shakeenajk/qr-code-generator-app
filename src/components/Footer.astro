---
const year = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-200 mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500">
        &copy; {year} QRCraft. Free to use, no signup required.
      </p>
      <nav aria-label="Footer navigation">
        <ul class="flex items-center gap-6 text-sm text-gray-500">
          <li><a href="/#faq" class="hover:text-gray-900 transition-colors">FAQ</a></li>
          <li><a href="/#qr-generator-root" class="hover:text-gray-900 transition-colors">Generator</a></li>
        </ul>
      </nav>
    </div>
  </div>
</footer>
