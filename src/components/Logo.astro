---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 40 } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 84 84"
  width={size}
  height={size}
  aria-label="QRCraft logo"
  role="img"
  class={`text-[#2563EB] ${className}`}
>
  <!-- Row 0: top bar (cols 2,3,4) -->
  <rect x="24" y="0"  width="10" height="10" fill="currentColor" />
  <rect x="36" y="0"  width="10" height="10" fill="currentColor" />
  <rect x="48" y="0"  width="10" height="10" fill="currentColor" />

  <!-- Row 1: left and right pillars (cols 1, 5) -->
  <rect x="12" y="12" width="10" height="10" fill="currentColor" />
  <rect x="60" y="12" width="10" height="10" fill="currentColor" />

  <!-- Row 2: left and right pillars (cols 1, 5) -->
  <rect x="12" y="24" width="10" height="10" fill="currentColor" />
  <rect x="60" y="24" width="10" height="10" fill="currentColor" />

  <!-- Row 3: left and right pillars (cols 1, 5) -->
  <rect x="12" y="36" width="10" height="10" fill="currentColor" />
  <rect x="60" y="36" width="10" height="10" fill="currentColor" />

  <!-- Row 4: left pillar, inner-right dot (cols 1, 4, 5) — starts Q tail setup -->
  <rect x="12" y="48" width="10" height="10" fill="currentColor" />
  <rect x="48" y="48" width="10" height="10" fill="currentColor" />
  <rect x="60" y="48" width="10" height="10" fill="currentColor" />

  <!-- Row 5: bottom bar (cols 2,3,4) -->
  <rect x="24" y="60" width="10" height="10" fill="currentColor" />
  <rect x="36" y="60" width="10" height="10" fill="currentColor" />
  <rect x="48" y="60" width="10" height="10" fill="currentColor" />

  <!-- Row 6: Q tail descender (col 5) -->
  <rect x="60" y="72" width="10" height="10" fill="currentColor" />
</svg>
