---
// src/pages/de/index.astro
import { useTranslations, getLocalizedHref } from '../../i18n/utils';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import QRGeneratorIsland from '../../components/QRGeneratorIsland';
import SeasonalTemplates from '../../components/SeasonalTemplates.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';

const t = useTranslations('de');

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: t('howto.heading'),
  description: t('meta.homeDescription'),
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: t('howto.step1.heading'),
      text: t('howto.step1.desc'),
      image: new URL('/screenshots/step-1.png', Astro.site).toString(),
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: t('howto.step2.heading'),
      text: t('howto.step2.desc'),
      image: new URL('/screenshots/step-2.png', Astro.site).toString(),
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: t('howto.step3.heading'),
      text: t('howto.step3.desc'),
      image: new URL('/screenshots/step-3.png', Astro.site).toString(),
    },
  ],
};

const teasers = [
  { icon: '🍽️', titleKey: 'usecases.teaser.restaurant', descKey: 'usecases.teaser.restaurant.desc', href: '/use-cases/restaurant-menu/' },
  { icon: '💼', titleKey: 'usecases.teaser.business', descKey: 'usecases.teaser.business.desc', href: '/use-cases/business-cards/' },
  { icon: '📦', titleKey: 'usecases.teaser.product', descKey: 'usecases.teaser.product.desc', href: '/use-cases/product-packaging/' },
  { icon: '🎉', titleKey: 'usecases.teaser.event', descKey: 'usecases.teaser.event.desc', href: '/use-cases/event-invitations/' },
  { icon: '📶', titleKey: 'usecases.teaser.wifi', descKey: 'usecases.teaser.wifi.desc', href: '/use-cases/wifi-sharing/' },
  { icon: '📱', titleKey: 'usecases.teaser.social', descKey: 'usecases.teaser.social.desc', href: '/use-cases/social-media/' },
] as const;

type TeaserKey = 'usecases.teaser.restaurant' | 'usecases.teaser.business' | 'usecases.teaser.product' | 'usecases.teaser.event' | 'usecases.teaser.wifi' | 'usecases.teaser.social' | 'usecases.teaser.restaurant.desc' | 'usecases.teaser.business.desc' | 'usecases.teaser.product.desc' | 'usecases.teaser.event.desc' | 'usecases.teaser.wifi.desc' | 'usecases.teaser.social.desc';

const features = [
  { icon: '🔗', titleKey: 'features.f1.title', descKey: 'features.f1.desc' },
  { icon: '🎨', titleKey: 'features.f2.title', descKey: 'features.f2.desc' },
  { icon: '🖼️', titleKey: 'features.f3.title', descKey: 'features.f3.desc' },
  { icon: '⬇️', titleKey: 'features.f4.title', descKey: 'features.f4.desc' },
  { icon: '⚡', titleKey: 'features.f5.title', descKey: 'features.f5.desc' },
  { icon: '🔒', titleKey: 'features.f6.title', descKey: 'features.f6.desc' },
] as const;

type FeatKey = 'features.f1.title' | 'features.f1.desc' | 'features.f2.title' | 'features.f2.desc' | 'features.f3.title' | 'features.f3.desc' | 'features.f4.title' | 'features.f4.desc' | 'features.f5.title' | 'features.f5.desc' | 'features.f6.title' | 'features.f6.desc';

const steps = [
  { number: 1, headingKey: 'howto.step1.heading', descKey: 'howto.step1.desc', imgSrc: '/screenshots/step-1.png', imgAlt: 'Schritt 1: Generator mit URL-Eingabefeld' },
  { number: 2, headingKey: 'howto.step2.heading', descKey: 'howto.step2.desc', imgSrc: '/screenshots/step-2.png', imgAlt: 'Schritt 2: Anpassungsfeld für Farben und Formen' },
  { number: 3, headingKey: 'howto.step3.heading', descKey: 'howto.step3.desc', imgSrc: '/screenshots/step-3.png', imgAlt: 'Schritt 3: Download-Dialog für PNG und SVG' },
] as const;

type StepKey = 'howto.step1.heading' | 'howto.step1.desc' | 'howto.step2.heading' | 'howto.step2.desc' | 'howto.step3.heading' | 'howto.step3.desc';
---

<Layout
  title={t('meta.homeTitle')}
  description={t('meta.homeDescription')}
  lang="de"
  showHreflang={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} slot="head" />

  <Header lang="de" />
  <main>
    <!-- Hero -->
    <section class="bg-white py-16 sm:py-24 dark:bg-[#0f172a]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 tracking-tight mb-6 dark:text-white">
          {t('hero.title')}
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-4 dark:text-slate-300">
          {t('hero.subtitle')}
        </p>
        <p class="text-sm text-gray-500 dark:text-slate-400 mb-6">
          {t('hero.proNote')} · <a href={getLocalizedHref('/pricing', 'de')} class="text-[#2563EB] hover:underline font-medium">{t('hero.proLink')}</a> {t('hero.proSuffix')}
        </p>
        <div
          id="qr-generator-root"
          class="bg-gray-50 rounded-xl border border-gray-200 p-6 text-left dark:bg-slate-800 dark:border-slate-700"
          aria-label="QR code generator"
        >
          <QRGeneratorIsland client:visible />
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="bg-gray-50 dark:bg-slate-900 py-16 sm:py-20" id="features">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white text-center mb-12">
          {t('features.heading')}
        </h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" role="list">
          {features.map((f) => (
            <li class="bg-white dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-6">
              <span class="text-3xl mb-3 block" aria-hidden="true">{f.icon}</span>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{t(f.titleKey as FeatKey)}</h3>
              <p class="text-gray-600 dark:text-slate-400 text-sm leading-relaxed">{t(f.descKey as FeatKey)}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- How-To -->
    <section class="bg-gray-50 dark:bg-[#0f172a] py-16 sm:py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center mb-12 text-gray-900 dark:text-white">
          {t('howto.heading')}
        </h2>
        <ol class="grid grid-cols-1 lg:grid-cols-3 gap-8" role="list">
          {steps.map((step) => (
            <li class="flex flex-col items-center text-center">
              <div class="w-11 h-11 rounded-full bg-[#2563EB] flex items-center justify-center mb-4 shrink-0">
                <span class="text-xl font-bold text-white" aria-hidden="true">{step.number}</span>
              </div>
              <img
                src={step.imgSrc}
                alt={step.imgAlt}
                class="w-full h-48 md:h-64 object-cover rounded-xl border border-gray-200 dark:border-slate-700 mb-4"
                loading="lazy"
                width="800"
                height="512"
              />
              <h3 class="text-base font-bold text-gray-900 dark:text-white mb-2">
                {t(step.headingKey as StepKey)}
              </h3>
              <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">
                {t(step.descKey as StepKey)}
              </p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Pricing Promo -->
    <section class="bg-white py-16 sm:py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center mb-12 text-gray-900 dark:text-white">
          {t('pricingpromo.heading')}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            <ul class="space-y-4" role="list">
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-700 dark:text-slate-300">{t('pricingpromo.bullet1')}</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-700 dark:text-slate-300">{t('pricingpromo.bullet2')}</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-700 dark:text-slate-300">{t('pricingpromo.bullet3')}</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-700 dark:text-slate-300">{t('pricingpromo.bullet4')}</span>
              </li>
            </ul>
            <a href={getLocalizedHref('/pricing', 'de')} class="text-sm text-[#2563EB] hover:underline font-bold">
              {t('pricingpromo.seeDetails')}
            </a>
          </div>
          <div class="space-y-4">
            <div class="bg-gray-50 dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-6">
              <p class="text-sm font-bold uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-3">{t('pricingpromo.freeTierLabel')}</p>
              <p class="text-base font-bold text-gray-900 dark:text-white mb-1">{t('pricingpromo.freeTierDesc')}</p>
              <p class="text-sm text-gray-600 dark:text-slate-400">{t('pricingpromo.freeTierSub')}</p>
            </div>
            <div class="bg-gray-50 dark:bg-slate-800 rounded-xl border border-[#2563EB] p-6">
              <p class="text-sm font-bold uppercase tracking-wide text-[#2563EB] mb-3">{t('pricingpromo.paidTierLabel')}</p>
              <p class="text-base font-bold text-gray-900 dark:text-white mb-1">{t('pricingpromo.paidTierDesc')}</p>
              <p class="text-sm text-gray-600 dark:text-slate-400">{t('pricingpromo.paidTierSub')}</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-3 pt-2">
              <a
                href="/signup"
                class="inline-block bg-[#2563EB] text-white text-sm font-bold px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors text-center focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
              >
                {t('pricingpromo.ctaFree')}
              </a>
              <a
                href={getLocalizedHref('/pricing', 'de')}
                class="inline-block border border-[#2563EB] text-[#2563EB] text-sm font-bold px-6 py-3 rounded-lg hover:bg-blue-50 dark:hover:bg-slate-700 transition-colors text-center focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
              >
                {t('pricingpromo.ctaPro')}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <SeasonalTemplates />

    <!-- Use Cases Teaser -->
    <section class="bg-gray-50 dark:bg-[#0f172a] py-16 sm:py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center mb-4 text-gray-900 dark:text-white">
          {t('usecases.heading')}
        </h2>
        <p class="text-base text-gray-600 dark:text-slate-400 text-center mb-12">
          {t('usecases.subheading')}
        </p>
        <ul class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-6" role="list">
          {teasers.map((teaser) => (
            <li>
              <a
                href={teaser.href}
                class="block bg-white dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-4 sm:p-6 hover:border-[#2563EB] transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
              >
                <span class="text-2xl mb-2 block" aria-hidden="true">{teaser.icon}</span>
                <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">
                  {t(teaser.titleKey as TeaserKey)}
                </h3>
                <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">
                  {t(teaser.descKey as TeaserKey)}
                </p>
              </a>
            </li>
          ))}
        </ul>
        <div class="text-center mt-8">
          <a
            href={getLocalizedHref('/use-cases/', 'de')}
            class="inline-flex items-center gap-2 text-[#2563EB] text-sm font-bold hover:underline focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 rounded"
          >
            {t('usecases.viewAll')}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <FAQ />
  </main>
  <Footer />
</Layout>
