---
// src/pages/use-cases/index.astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SEO } from 'astro-seo';
import { USE_CASES } from '../../data/useCases';

const canonicalUrl = new URL('/use-cases/', Astro.site).toString();

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: Astro.site?.toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Use Cases',
      item: canonicalUrl,
    },
  ],
};
---

<Layout
  title="QR Code Use Cases — QRCraft"
  description="Discover how to use QR codes for restaurant menus, business cards, product packaging, events, and more. Free QR code generator."
  showHreflang={true}
>
  <SEO
    slot="head"
    title="QR Code Use Cases — QRCraft"
    description="Discover how to use QR codes for restaurant menus, business cards, product packaging, events, and more. Free QR code generator."
    canonical={canonicalUrl}
    openGraph={{
      basic: {
        title: 'QR Code Use Cases — QRCraft',
        type: 'website',
        image: new URL('/og-image.png', Astro.site).toString(),
        url: canonicalUrl,
      },
      optional: {
        description: 'Discover how to use QR codes for restaurant menus, business cards, product packaging, events, and more. Free QR code generator.',
        siteName: 'QRCraft',
      },
    }}
  />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <Header />
  <main>
    <section class="bg-white py-16 sm:py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          QR Code Use Cases
        </h1>
        <p class="text-base text-gray-600 dark:text-slate-400 mb-12">
          Explore how businesses and individuals use QR codes to connect print and digital experiences.
        </p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6" role="list">
          {USE_CASES.map((useCase) => (
            <li>
              <a
                href={`/use-cases/${useCase.slug}/`}
                class="block bg-gray-50 dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-6 hover:border-[#2563EB] transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
              >
                <h2 class="text-base font-bold text-gray-900 dark:text-white mb-2">
                  {useCase.title}
                </h2>
                <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">
                  {useCase.excerpt}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
