---
export const prerender = false;
import DashboardLayout from '../../components/dashboard/DashboardLayout.astro';
import ApiKeyManagerIsland from '../../components/dashboard/ApiKeyManagerIsland';
import { Toaster } from 'sonner';
import { db } from '../../db/index';
import { subscriptions } from '../../db/schema';
import { eq } from 'drizzle-orm';

// Middleware (src/middleware.ts) already redirects unauthenticated users to /login.
// This is a belt-and-suspenders check in case middleware is misconfigured.
const { userId } = Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/login');
}

// Query subscription status directly (avoids self-fetch which can fail in SSR)
const sub = await db.query.subscriptions.findFirst({
  where: eq(subscriptions.userId, userId),
});
const status = sub?.status ?? 'inactive';
const rawTier = status === 'active' || status === 'past_due' ? (sub?.tier ?? 'free') : 'free';
const tier = rawTier as 'free' | 'starter' | 'pro';
---

<DashboardLayout activeSection="api-keys" title="API Keys — QRCraft" tier={tier}>
  <div class="p-6 md:p-8">
    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">API Keys</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">
        Manage your API keys for programmatic QR code generation.
      </p>
    </div>

    {tier === 'pro' ? (
      <ApiKeyManagerIsland client:load />
    ) : (
      <div class="flex items-center justify-center py-16">
        <div class="text-center max-w-md">
          <div class="mx-auto mb-4 w-12 h-12 rounded-full bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
            API Keys require a Pro subscription
          </h2>
          <p class="text-sm text-gray-500 dark:text-slate-400 mb-6">
            Upgrade to Pro to generate QR codes programmatically via our REST API.
          </p>
          <a
            href="/pricing"
            class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors"
          >
            Upgrade to Pro
          </a>
        </div>
      </div>
    )}

    <Toaster client:load richColors position="top-right" />
  </div>
</DashboardLayout>
