---
export const prerender = false;
import DashboardLayout from '../../../components/dashboard/DashboardLayout.astro';
import { EditLandingPageForm } from '../../../components/EditLandingPageForm';
import { Toaster } from 'sonner';

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect('/sign-in');

const { id } = Astro.params;
if (!id) return Astro.redirect('/dashboard');
---

<DashboardLayout activeSection="library">
  <div class="max-w-2xl mx-auto px-4 py-8">
    <h1 class="text-xl font-bold text-gray-900 dark:text-slate-100 mb-6">Edit Landing Page</h1>
    <EditLandingPageForm client:load landingPageId={id} />
  </div>
  <Toaster client:only="react" theme="system" position="bottom-right" />
</DashboardLayout>
