---
export const prerender = false;
import DashboardLayout from '../../components/dashboard/DashboardLayout.astro';
import PaymentFailureBanner from '../../components/billing/PaymentFailureBanner.astro';
import SubscriptionPolling from '../../components/billing/SubscriptionPolling';
import QRLibrary from '../../components/dashboard/QRLibrary';
import { Toaster } from 'sonner';
import { db } from '../../db/index';
import { subscriptions } from '../../db/schema';
import { eq } from 'drizzle-orm';

// Middleware (src/middleware.ts) already redirects unauthenticated users to /login.
// This is a belt-and-suspenders check in case middleware is misconfigured.
const { userId } = Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/login');
}

// Query subscription status directly (avoids self-fetch which can fail in SSR)
const sub = await db.query.subscriptions.findFirst({
  where: eq(subscriptions.userId, userId),
});
const status = sub?.status ?? 'inactive';
const tier = status === 'active' || status === 'past_due' ? (sub?.tier ?? 'free') : 'free';
const paymentFailed = status === 'past_due';
---

<DashboardLayout activeSection="my-qr-codes" title="My QR Codes — QRCraft" tier={tier}>
  <!-- Payment failure banner (sticky at top of main content) -->
  <PaymentFailureBanner show={paymentFailed} />

  <!-- Post-checkout subscription polling (activates on ?upgraded=true) -->
  <SubscriptionPolling client:only="react" />

  <div class="p-6 md:p-8">
    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">My QR Codes</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">
        Your saved QR codes. Save from the generator to build your library.
      </p>
    </div>

    <!-- QR Library — replaces Phase 7 placeholder -->
    <QRLibrary client:only="react" />
    <Toaster client:only="react" theme="system" position="bottom-right" />
  </div>
</DashboardLayout>
