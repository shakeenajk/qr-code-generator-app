---
export const prerender = false;
import DashboardLayout from '../../components/dashboard/DashboardLayout.astro';
import PaymentFailureBanner from '../../components/billing/PaymentFailureBanner.astro';
import SubscriptionPolling from '../../components/billing/SubscriptionPolling';

// Middleware (src/middleware.ts) already redirects unauthenticated users to /login.
// This is a belt-and-suspenders check in case middleware is misconfigured.
const { userId } = Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/login');
}

// Fetch subscription status server-side to pass tier to components
const subRes = await fetch(`${import.meta.env.PUBLIC_BASE_URL}/api/subscription/status`, {
  headers: { cookie: Astro.request.headers.get('cookie') ?? '' }
});
const { tier, paymentFailed } = subRes.ok
  ? await subRes.json()
  : { tier: 'free', paymentFailed: false };
---

<DashboardLayout activeSection="my-qr-codes" title="My QR Codes — QRCraft" tier={tier}>
  <!-- Payment failure banner (sticky at top of main content) -->
  <PaymentFailureBanner show={paymentFailed} />

  <!-- Post-checkout subscription polling (activates on ?upgraded=true) -->
  <SubscriptionPolling client:only="react" />

  <div class="p-6 md:p-8">
    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">My QR Codes</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">
        Your saved QR codes will appear here. Save your first QR code from the generator.
      </p>
    </div>

    <!-- Empty state — Phase 9 will replace this with the QR library grid -->
    <div class="flex flex-col items-center justify-center py-16 px-4 text-center rounded-xl border-2 border-dashed border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900">
      <div class="w-16 h-16 rounded-full bg-gray-100 dark:bg-slate-800 flex items-center justify-center mb-4">
        <svg class="w-8 h-8 text-gray-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zm0 9.75c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zm9.75-9.75c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z" />
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-gray-700 dark:text-slate-300 mb-2">No QR codes saved yet</h2>
      <p class="text-sm text-gray-500 dark:text-slate-400 mb-6 max-w-xs">
        Generate a QR code on the homepage and save it to your library. Available in a future update.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-[#2563EB] text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors"
      >
        Go to Generator
      </a>
    </div>
  </div>
</DashboardLayout>
