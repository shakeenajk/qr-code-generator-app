---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import HowTo from '../components/HowTo.astro';
import PricingPromo from '../components/PricingPromo.astro';
import SeasonalTemplates from '../components/SeasonalTemplates.astro';
import UseCasesTeaser from '../components/UseCasesTeaser.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Create a QR Code in 3 Steps',
  description: 'Generate a custom QR code for free using QRCraft.',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Choose your content type',
      text: 'Enter a URL, text, WiFi credentials, or contact details.',
      image: new URL('/screenshots/step-1.png', Astro.site).toString(),
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Customize the design',
      text: 'Pick colors, dot shapes, and embed your logo.',
      image: new URL('/screenshots/step-2.png', Astro.site).toString(),
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Download instantly',
      text: 'Export as PNG or SVG — no account needed.',
      image: new URL('/screenshots/step-3.png', Astro.site).toString(),
    },
  ],
};
---

<Layout
  title="Free QR Code Generator — QRCraft"
  description="Create custom QR codes for URLs, WiFi, contact cards, and text. Download as PNG or SVG instantly. Free, no signup required."
>
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} slot="head" />

  <Header />
  <main>
    <Hero />
    <Features />
    <HowTo />
    <PricingPromo />
    <SeasonalTemplates />
    <UseCasesTeaser />
    <FAQ />
  </main>
  <Footer />
</Layout>
