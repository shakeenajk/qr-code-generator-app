---
// src/pages/es/use-cases/index.astro
import { useTranslations } from '../../../i18n/utils';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { USE_CASES } from '../../../data/useCases';

const t = useTranslations('es');

const slugToKey: Record<string, string> = {
  'restaurant-menu': 'restaurant',
  'business-cards': 'business',
  'product-packaging': 'product',
  'event-invitations': 'event',
  'wifi-sharing': 'wifi',
  'social-media': 'social',
};

const canonicalUrl = new URL('/es/use-cases/', Astro.site).toString();

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: new URL('/es/', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t('usecases.page.heading'),
      item: canonicalUrl,
    },
  ],
};
---

<Layout
  title={t('meta.usecasesTitle')}
  description={t('meta.usecasesDescription')}
  lang="es"
  showHreflang={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <Header lang="es" />
  <main>
    <section class="bg-white py-16 sm:py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          {t('usecases.page.heading')}
        </h1>
        <p class="text-base text-gray-600 dark:text-slate-400 mb-12">
          {t('usecases.page.subheading')}
        </p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6" role="list">
          {USE_CASES.map((useCase) => {
            const key = slugToKey[useCase.slug] || useCase.slug;
            const title = t(`usecases.teaser.${key}` as any) || useCase.title;
            const desc = t(`usecases.teaser.${key}.desc` as any) || useCase.excerpt;
            return (
            <li>
              <a
                href={`/use-cases/${useCase.slug}/`}
                class="block bg-gray-50 dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-6 hover:border-[#2563EB] transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
              >
                <h2 class="text-base font-bold text-gray-900 dark:text-white mb-2">
                  {title}
                </h2>
                <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">
                  {desc}
                </p>
              </a>
            </li>
            );
          })}
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
