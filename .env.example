# =============================================================================
# QRCraft environment variables
# Copy this file to .env.local and fill in real values for local development.
# For production, set these in Vercel → Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk (auth) — required
# -----------------------------------------------------------------------------
# Dev: pk_test_... / sk_test_...
# Prod: pk_live_... / sk_live_... (requires Clerk production instance + DNS setup)
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Turso (database) — required
# -----------------------------------------------------------------------------
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Stripe (payments) — required for monetization
# -----------------------------------------------------------------------------
# Dev: sk_test_... / pk_test_...
# Prod: sk_live_... (requires Stripe account activation)
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook signing secret — get from Stripe Dashboard → Developers → Webhooks
# Each webhook endpoint has its own secret. Test mode and live mode are separate.
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe price IDs — must be set BOTH with and without PUBLIC_ prefix.
# - PUBLIC_* versions are inlined into the client-side JS bundle (pricing page)
# - Non-PUBLIC versions are read server-side by lib/billing.ts (webhook handler)
# The values are identical; only the variable names differ.
STRIPE_PRICE_STARTER_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_STARTER_ANNUAL=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PRO_ANNUAL=price_XXXXXXXXXXXXXXXXXXXXXXXX

PUBLIC_STRIPE_PRICE_STARTER_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
PUBLIC_STRIPE_PRICE_STARTER_ANNUAL=price_XXXXXXXXXXXXXXXXXXXXXXXX
PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_XXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# App config — required
# -----------------------------------------------------------------------------
# Used for Stripe success_url, cancel_url, and other absolute URL construction.
# Local: http://localhost:4321
# Production: https://www.qr-code-generator-app.com (note the canonical www)
PUBLIC_BASE_URL=http://localhost:4321

# -----------------------------------------------------------------------------
# Vercel Blob (file uploads for hosted landing pages) — required
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Cron secret — required (used by /api/cron/* endpoints)
# -----------------------------------------------------------------------------
# Generate any random string. Must match the secret your cron service sends.
CRON_SECRET=any-long-random-string

# -----------------------------------------------------------------------------
# Google AdSense — optional (free-tier ad serving)
# -----------------------------------------------------------------------------
PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_ADSENSE_SLOT=1234567890

# -----------------------------------------------------------------------------
# Upstash Redis — optional (rate limiting; gracefully degrades if missing)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://XXXXXXXX.upstash.io
UPSTASH_REDIS_REST_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Sentry — optional but strongly recommended (error tracking + source maps)
# -----------------------------------------------------------------------------
PUBLIC_SENTRY_DSN=https://XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_AUTH_TOKEN=sntrys_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
