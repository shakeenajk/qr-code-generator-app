{
  "ci": {
    "collect": {
      "url": ["http://localhost:4323/"],
      "numberOfRuns": 3,
      "settings": {
        "formFactor": "mobile",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 4
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }]
      }
    }
  }
}
